/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  padding: 40rpx 30rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.month-selector {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.arrow {
  font-size: 48rpx;
  color: #fff;
  padding: 0 30rpx;
  font-weight: bold;
}

.month-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.total-box {
  text-align: center;
}

.total-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}

.total-amount {
  font-size: 64rpx;
  color: #fff;
  font-weight: bold;
}

/* 列表 */
.list {
  padding: 20rpx 30rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 10rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
}

.record-count {
  color: #999;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 32rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 25rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.record-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.category {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.note {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.date {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 2rpx;
}

.record-right {
  display: flex;
  align-items: center;
}

.amount {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: bold;
  margin-right: 20rpx;
}

.delete-btn {
  font-size: 36rpx;
  color: #ccc;
  padding: 0 10rpx;
}

.delete-btn:active {
  color: #FF6B6B;
}

/* 添加按钮 */
.add-btn-wrapper {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
}

.add-btn {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 90rpx;
  line-height: 90rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
}

.add-btn:active {
  opacity: 0.8;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 85%;
  max-height: 80vh;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 25rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.category-select {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.category-tag {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: #e8e8e8;
  color: #333;
}

.category-tag:active {
  opacity: 0.6;
}

.date-picker {
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 70rpx;
  color: #333;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btns button {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.btn-confirm {
  background: #4CAF50;
  color: #fff;
}