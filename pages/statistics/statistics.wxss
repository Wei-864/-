/* pages/statistics/statistics.wxss *//* pages/statistics/statistics.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 30rpx 40rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  margin: 0 -30rpx;
  padding: 40rpx 30rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}

.month-selector {
  display: flex;
  justify-content: center;
  align-items: center;
}

.arrow {
  font-size: 48rpx;
  color: #fff;
  padding: 0 30rpx;
  font-weight: bold;
}

.month-text {
  font-size: 32rpx;
  color: #fff;
}

/* 汇总卡片 */
.summary {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-top: -20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-item .label {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.summary-item .value {
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-top: 10rpx;
}

/* 分类统计 */
.chart {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 20rpx;
  padding: 30rpx 25rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.chart-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.chart-item {
  margin-bottom: 25rpx;
}

.chart-item:last-child {
  margin-bottom: 0;
}

.chart-label {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.chart-label text:first-child {
  font-weight: bold;
}

.chart-label text:last-child {
  color: #666;
}

.chart-bar {
  height: 24rpx;
  background: #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
}

.chart-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

.chart-count {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}